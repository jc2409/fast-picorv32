  if [ -f $i ]; then \
    j=`echo $i | sed -e 's/-new//'`; \
    k=`echo $j | sed 's&^&riscv32-unknown-elf-&'`; \
    if [ "/opt/riscv32im/bin/$k" != "/opt/riscv32im/riscv32-unknown-elf/bin/$j" ]; then \
      rm -f /opt/riscv32im/riscv32-unknown-elf/bin/$j; \
      ln /opt/riscv32im/bin/$k /opt/riscv32im/riscv32-unknown-elf/bin/$j >/dev/null 2>/dev/null \
	||  /bin/bash ./libtool --mode=install /usr/bin/install -c $i /opt/riscv32im/riscv32-unknown-elf/bin/$j; \
    fi; \
  else true; \
  fi; \
done
